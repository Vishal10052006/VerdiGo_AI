DATABASE_URL=postgresql://verdigo:verdigo_test_pw@localhost:5432/verdigo_test

# Copy every other required var from .env (JWT secrets, weather keys, etc.)
# — pydantic-settings needs all required fields present or Settings() will fail to load.
JWT_SECRET_KEY=<same as .env, or any test value>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
WEATHERAPI_API_KEY=test-key
WEATHERAPI_BASE_URL=https://api.weatherapi.com/v1
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
PRIMARY_WEATHER_PROVIDER=weatherapi
FALLBACK_WEATHER_PROVIDER=openmeteo
WEATHER_REQUEST_TIMEOUT=10
WEATHER_CACHE_MINUTES=30
ALLOWED_ORIGINS=http://localhost:3000
STORAGE_PROVIDER=local